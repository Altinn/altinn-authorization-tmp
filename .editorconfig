# top-most EditorConfig file
root = true

# For all files
[*]
insert_final_newline = true
tab_width = 2
charset = utf-8-bom

[*.{tf,tfvars}]
charset = utf-8

[*.{props,targets,csproj}]
tab_width = 4

[*.cs]
tab_width = 4

# VSTHRD200: Use "Async" suffix for async methods
dotnet_diagnostic.VSTHRD200.severity = none

# SA1001: Commas should be spaced correctly
dotnet_diagnostic.SA1001.severity = none

# SA1117: Parameters should all be on same line or each on its own
# (codebase consistently uses "first arg + remaining args grouped" for
# logger / validation / builder calls)
dotnet_diagnostic.SA1117.severity = none

# FAA0002: Replace Xunit assertion with Fluent Assertions equivalent
dotnet_diagnostic.FAA0002.severity = none

# CA1822: Mark members as static
dotnet_diagnostic.CA1822.severity = none

# Test projects: documentation not required (test names are self-documenting)
[**/test/**/*.cs]

# SA1600: Elements should be documented
dotnet_diagnostic.SA1600.severity = none

# SA1316: Tuple element naming convention - test code uses camelCase
dotnet_diagnostic.SA1316.severity = none

<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Clear the singular TargetFramework inherited from src/Directory.Build.props so
             dotnet test routes to the Microsoft Testing Platform (required for xUnit v3). -->
        <TargetFramework></TargetFramework>
        <TargetFrameworks>net10.0</TargetFrameworks>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Altinn.Authorization.Integration.Platform\Altinn.Authorization.Integration.Platform.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Update="testsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <Content Include="xunit.runner.json" CopyToOutputDirectory="Always" />
    </ItemGroup>

</Project>

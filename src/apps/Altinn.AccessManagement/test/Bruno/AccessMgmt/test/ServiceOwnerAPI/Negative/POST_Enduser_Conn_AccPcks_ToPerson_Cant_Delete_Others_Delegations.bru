meta {
  name: POST_Enduser_Conn_AccPcks_ToPerson_Cant_Delete_Others_Delegations
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections/accesspackages?party={{party}}&from={{party}}&to={{toPersonPartyUuid}}&packageId&package={{package}}
  body: json
  auth: inherit
}

params:query {
  party: {{party}}
  from: {{party}}
  to: {{toPersonPartyUuid}}
  packageId: 
  package: {{package}}
}

headers {
  Accept: application/json
}

body:json {
   {
    "personidentifier": "{{toPerson}}", // fnr or username
    "lastName": "{{toPersonLastName}}"
  }
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/serviceowner/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.privat_person_A.partyuuid);
  bru.setVar("toPerson", testdata.privat_person_B.pid);
  bru.setVar("toPersonLastName", testdata.privat_person_B.lastname);
  bru.setVar("toPersonPartyUuid", testdata.privat_person_B.partyuuid);
  bru.setVar("package", testdata.package_to_delegate.skatteforhold_priv);
  
  var getTokenParameters = {
    auth_userId: testdata.privat_person_A.userid,
    auth_partyId: testdata.privat_person_A.partyid,
    auth_partyUuid: testdata.privat_person_A.partyuuid,
    auth_ssn: testdata.privat_person_A.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken",  token);
}

docs {
  Gir tilgangspakke til person
}

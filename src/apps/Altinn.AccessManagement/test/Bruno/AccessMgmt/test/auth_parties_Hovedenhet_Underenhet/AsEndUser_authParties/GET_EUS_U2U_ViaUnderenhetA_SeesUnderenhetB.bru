meta {
  name: GET_EUS_U2U_ViaUnderenhetA_SeesUnderenhetB
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/authorizedparties?includeRoles=true&includeAccessPackages=true&includeResources=true&includeInstances=true
  body: json
  auth: inherit
}

params:query {
  includeRoles: true
  includeAccessPackages: true
  includeResources: true
  includeInstances: true
}

headers {
  Content-Type: application/json
  Accept: application/json
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/auth-parties-testdata/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("requestName", "GET_EUS_U2U_DagliglederC_SeesHovedenhetD");
  
  // UnderenhetA delegated to UnderenhetD, so DagliglederC authenticates
  var getTokenParameters = {
    auth_userId: testdata.authParties_hovedenhetC.dagligleder.userid,
    auth_partyId: testdata.authParties_hovedenhetC.dagligleder.partyid,
    auth_partyUuid: testdata.authParties_hovedenhetC.dagligleder.partyuuid,
    auth_ssn: testdata.authParties_hovedenhetC.dagligleder.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.authorizedParties
  }
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/auth-parties-testdata/${bru.getEnvVar("tokenEnv")}.js`);
  const body = res.getBody().data;
  const requestName = bru.getVar("requestName");
  
  // ── Helper: flatten all parties including subunits ──
  const flattenParties = (parties) => (parties || []).flatMap(p => [p, ...(p.subunits || [])]);
  
  // ── Step 1: Response status ──
  test(requestName + '|Step1: Response status is 200 OK', function() {
    expect(res.status).to.equal(200);
  });
  
  // ── Step 2: HovedenhetD has no access, UnderenhetD has expected access ──
  test(requestName + '|HovedenhetD has no access, UnderenhetD has expected access', function() {
  
    const hovedenhet = (body || []).find(
      p => p.partyUuid === testdata.authParties_hovedenhetD.partyuuid
    );
  
    assert.exists(hovedenhet,'Expected HovedenhetD to exist as top-level party');
  
    const underenhet = (hovedenhet.subunits || []).find(
      s => s.partyUuid === testdata.authParties_hovedenhetD.authParties_underenhetD.partyuuid
    );
  
    assert.exists(underenhet,'Expected UnderenhetD to exist under HovedenhetD'
    );
  
    // Hovedenhet should have no access
    expect(hovedenhet.authorizedAccessPackages || []).to.have.length(0);
    expect(hovedenhet.authorizedResources || []).to.have.length(0);
    expect(hovedenhet.authorizedRoles || []).to.have.length(0);
    expect(hovedenhet.authorizedInstances || []).to.have.length(0);
  
    // Underenhet should have expected packages
    expect(underenhet.authorizedAccessPackages || []).to.have.members([
      "damp-varmtvann",
      "finansiering-og-forsikring",
      "informasjon-og-kommunikasjon",
      "utvinning-raaolje-naturgass-kull"
    ]);
  
    // Underenhet should have expected resources
    expect(underenhet.authorizedResources || []).to.have.members([
      "app_ttd_instance-gui-test",
      "app_ttd_security-level3-app",
      "app_ttd_ttd-bruno-tilgangspakke-app"
    ]);
    
     expect(underenhet.authorizedRoles || []).to.have.length(0);
  });
  
  // ── Step 3: UnderenhetD has delegated instance access ──
  test(requestName + '|UnderenhetD has delegated instance access', function() {
  
    const hovedenhet = (body || []).find(
      p => p.partyUuid === testdata.authParties_hovedenhetD.partyuuid
    );
  
    const underenhet = (hovedenhet.subunits || []).find(
      s => s.partyUuid === testdata.authParties_hovedenhetD.authParties_underenhetD.partyuuid
    );
  expect(underenhet.authorizedInstances || []).to.have.length(1);
  
    const instance = underenhet.authorizedInstances[0];
  
    expect(instance.resourceId)
      .to.equal("app_ttd_signering-brukerstyrt");
  
    expect(instance.instanceRef)
      .to.equal(testdata.instancer.underenhetD_instansid);
  });
}

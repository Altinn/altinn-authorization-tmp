meta {
  name: GET_EUS_U2H_DagliglederB_SeesUnderenhetC
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/authorizedparties?includeRoles=true&includeAccessPackages=true&includeResources=true
  body: json
  auth: inherit
}

params:query {
  includeRoles: true
  includeAccessPackages: true
  includeResources: true
}

headers {
  Content-Type: application/json
  Accept: application/json
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/auth-parties-testdata/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("requestName", "GET_EUS_U2H_DagliglederB_SeesUnderenhetC");
  
  // UnderenhetA delegated to HovedenhetB, so DagliglederB (recipient's DAGL) authenticates
  var getTokenParameters = {
    auth_userId: testdata.authParties_hovedenhetB.dagligleder.userid,
    auth_partyId: testdata.authParties_hovedenhetB.dagligleder.partyid,
    auth_partyUuid: testdata.authParties_hovedenhetB.dagligleder.partyuuid,
    auth_ssn: testdata.authParties_hovedenhetB.dagligleder.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.authorizedParties
  }
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/auth-parties-testdata/${bru.getEnvVar("tokenEnv")}.js`);
  const body = res.getBody().data;
  const requestName = bru.getVar("requestName");
  
  // ── Helper: flatten all parties including subunits ──
  const flattenParties = (parties) => (parties || []).flatMap(p => [p, ...(p.subunits || [])]);
  
  // ── Step 1: Response status ──
  test(requestName + '|Step1: Response status is 200 OK', function() {
    expect(res.status).to.equal(200);
  });
  
  // ── Step 2: HovedenhetC has no access, UnderenhetC has expected access ──
  test(requestName + '|HovedenhetC has no access, UnderenhetC has expected access', function() {
  
    const hovedenhet = (body || []).find(
      p => p.partyUuid === testdata.authParties_hovedenhetC.partyuuid
    );
  
    assert.exists(
      hovedenhet,
      'Expected HovedenhetC to exist as top-level party'
    );
  
    const underenhet = (hovedenhet.subunits || []).find(
      s => s.partyUuid === testdata.authParties_hovedenhetC.authParties_underenhetC.partyuuid
    );
  
    assert.exists(
      underenhet,
      'Expected UnderenhetC to exist under HovedenhetC'
    );
  
    // Hovedenhet should have no access
    expect(hovedenhet.authorizedAccessPackages || [])
      .to.have.length(0);
  
    expect(hovedenhet.authorizedResources || [])
      .to.have.length(0);
  
    expect(hovedenhet.authorizedRoles || [])
      .to.have.length(0);
  
    expect(hovedenhet.authorizedInstances || [])
      .to.have.length(0);
  
    // Underenhet should have expected access packages
    expect(underenhet.authorizedAccessPackages || [])
      .to.have.members([
        "elektronisk-kommunikasjon",
        "finansiering-og-forsikring",
        "informasjon-og-kommunikasjon",
        "kommuneoverlege",
        "pleie-omsorgstjenester-i-institusjon"
      ]);
  
    // Underenhet should have expected resources
    expect(underenhet.authorizedResources || [])
      .to.have.members([
        "app_ttd_security-level3-app"
      ]);
  
    expect(underenhet.authorizedRoles || [])
      .to.have.length(0);
  
    expect(underenhet.authorizedInstances || [])
      .to.have.length(0);
  });
}

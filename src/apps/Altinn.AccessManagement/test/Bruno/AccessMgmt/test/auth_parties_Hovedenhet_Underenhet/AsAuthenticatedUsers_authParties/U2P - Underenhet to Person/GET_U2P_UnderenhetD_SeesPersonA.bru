meta {
  name: GET_U2P_UnderenhetD_SeesPersonA
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/authorizedparties?includeAltinn2=true&includeAltinn3=true&includeAccessPackages=true
  body: json
  auth: inherit
}

params:query {
  includeAltinn2: true
  includeAltinn3: true
  includeAccessPackages: true
}

headers {
  Content-Type: application/json
  Accept: application/json
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/auth-parties-testdata/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("requestName", "GET_P2U_PersonA_SeesUnderenhetB");
  
  // PersonA has access to UnderenhetB (sub-unit), PersonA authenticates
  var getTokenParameters = {
    auth_userId: testdata.authParties_personA.userid,
    auth_partyId: testdata.authParties_personA.partyid,
    auth_partyUuid: testdata.authParties_personA.partyuuid,
    auth_ssn: testdata.authParties_personA.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/auth-parties-testdata/${bru.getEnvVar("tokenEnv")}.js`);
  const body = res.getBody();
  const requestName = bru.getVar("requestName");
  
  // ── Helper: flatten all parties including subunits ──
  const flattenParties = (parties) => (parties || []).flatMap(p => [p, ...(p.subunits || [])]);
  
  // ── Step 1: Response status ──
  test(requestName + '|Step1: Response status is 200 OK', function() {
    expect(res.status).to.equal(200);
  });
  
  test(requestName + '|Step2: HovedenhetD has no access', function() {
    const hovedenhet = (body || []).find(
      p => p.partyUuid === testdata.authParties_hovedenhetD.partyuuid
    );
  
    assert.exists(
      hovedenhet,
      'Expected HovedenhetD (partyUuid: ' + testdata.authParties_hovedenhetD.partyuuid + ') to exist as top-level party'
    );
  
    expect(hovedenhet.authorizedAccessPackages || []).to.have.length(0);
    expect(hovedenhet.authorizedResources || []).to.have.length(0);
    expect(hovedenhet.authorizedRoles || []).to.have.length(0);
    expect(hovedenhet.authorizedInstances || []).to.have.length(0);
  });
  
  
  // ── Step 3: UnderenhetD exists under HovedenhetD with expected access data ──
  test(requestName + '|Step3: UnderenhetD exists under HovedenhetD with expected access data', function() {
    const hovedenhet = (body || []).find(
      p => p.partyUuid === testdata.authParties_hovedenhetD.partyuuid
    );
  
    assert.exists(hovedenhet, 'Expected HovedenhetD to exist as top-level party');
  
    const underenhet = (hovedenhet.subunits || []).find(
      s => s.partyUuid === testdata.authParties_hovedenhetD.authParties_underenhetD.partyuuid
    );
  
    assert.exists(underenhet, 'Expected UnderenhetD to exist under HovedenhetD');
  
    expect(underenhet.authorizedAccessPackages || []).to.have.members([
      "beredskap",
      "byggesoknad",
      "motta-nabo-og-planvarsel",
      "patent-varemerke-design"
    ]);
  
    expect(underenhet.authorizedResources || []).to.have.length(0);
    expect(underenhet.authorizedRoles || []).to.have.length(0);
  });
  
  
  // ── Step 4: No duplicate parties ──
  test(requestName + '|Step4: No duplicate parties in response', function() {
    const allUuids = flattenParties(body).map(p => p.partyUuid);
    const seen = {};
    const dupes = allUuids.filter(uuid => {
      seen[uuid] = (seen[uuid] || 0) + 1;
      return seen[uuid] === 2;
    });
  
    expect(dupes.length, `Duplicate partyUuids: ${dupes.join(', ')}`).to.equal(0);
  });
  
  
  test(requestName + '|Step5: Instance access exists only on UnderenhetD', function() {
    const hovedenhet = (body || []).find(
      p => p.partyUuid === testdata.authParties_hovedenhetD.partyuuid
    );
  
    assert.exists(hovedenhet, 'Expected HovedenhetD to exist as top-level party');
  
    const underenhet = (hovedenhet.subunits || []).find(
      s => s.partyUuid === testdata.authParties_hovedenhetD.authParties_underenhetD.partyuuid
    );
  
    assert.exists(underenhet, 'Expected UnderenhetD to exist under HovedenhetD');
  
    expect(hovedenhet.authorizedInstances || []).to.have.length(0);
  
    const instance = (underenhet.authorizedInstances || []).find(
      i => i.instanceRef === testdata.instancer.underenhetD_instansid
    );
  
    assert.exists(instance, 'Expected delegated instanceRef to exist on UnderenhetD');
  
    expect(instance.resourceId)
      .to.equal("app_ttd_ttd-bruno-tilgangspakke-app");
  });
  
  
}

meta {
  name: POST_Serviceowner_request_For_Be_om_tilgang
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/serviceowner/delegationrequests/resource
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
  "from": "urn:altinn:person:identifier-no:{{from}}",
    "to": "urn:altinn:organization:identifier-no:{{toOrg}}",
    "resource": "{{resource}}"
  }
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    bru.setVar("from", testdata.Bot_person_serviceowner.pid);
    bru.setVar("toOrg", testdata.Bot_Org_for_serviceowner.org_no);
    bru.setVar("resource", testdata.resource_to_delegate.resource_id_privatperson);
    
    var getTokenParameters = {
      auth_org: sharedtestdata.serviceOwners.ttd.org,
      auth_orgNo: sharedtestdata.serviceOwners.digdir.orgno,
      auth_tokenType: sharedtestdata.authTokenType.enterprise,
      auth_scopes: sharedtestdata.auth_scopes.serviceownerDelegationRequestWrite
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    test("Person_A request for access on resources to Org_user via serviceowner API", function() {
      const data = res.getBody();
      
      expect(res.status).to.equal(202);
      expect(data).to.exist;
      expect(data.id).to.exist;
      expect(data.status).to.exist;
      
       // 2. Verify and save requestId
     expect(data).to.have.property("id");
     bru.setEnvVar("serviceowner_requestId", data.id);
      
      // 3. Verify and save status
    expect(data).to.have.property("status");
    bru.setEnvVar("expectedStatus", data.status);
      
    });
}

settings {
  encodeUrl: true
  timeout: 0
}

meta {
  name: PUT_Withdraw_Package_Request
  type: http
  seq: 12
}

put {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/request/sent/withdraw?party={{party}}&id={{resourcerequestId}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  id: {{resourcerequestId}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    bru.setVar("party", testdata.Bot_package_Org.partyuuid);
    
     var getTokenParameters = {
      auth_userId: testdata.Bot_package_Org.innehaver.userid,
      auth_partyId: testdata.Bot_package_Org.innehaver.partyid,
      auth_partyUuid: testdata.Bot_package_Org.innehaver.partyuuid,
      auth_ssn: testdata.Bot_package_Org.innehaver.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.sluttbrukerdelegationrequestwrite
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    test("Withdraw package request which was sent from Person", function() {
      const data = res.getBody();
      
      expect(res.status).to.equal(200);
      expect(data).to.exist;
      expect(data.id).to.exist;
      expect(data).to.have.property("id");
    expect(data).to.have.property("status").that.is.oneOf(["Withdrawn"]);
    expect(data).to.have.property("type", "package");
    
    // Resource check
    expect(data.package).to.exist;
    expect(data.package).to.have.property(
      "referenceId",
      testdata.package_to_delegate.package_id_privatperson_withdraw
    );
    
    // From / To check
    expect(data.from).to.have.property("id", testdata.Bot_package_Org.partyuuid);
    expect(data.to).to.have.property("id", testdata.Bot_package_person_withdraw.partyuuid);
    });
}

settings {
  encodeUrl: true
  timeout: 0
}

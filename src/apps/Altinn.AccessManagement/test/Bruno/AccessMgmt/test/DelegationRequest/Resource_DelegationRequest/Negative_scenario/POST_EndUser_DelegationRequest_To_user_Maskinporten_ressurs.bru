meta {
  name: POST_EndUser_DelegationRequest_To_user_Maskinporten_ressurs
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/request/resource?party={{party}}&to={{toUser}}&resource={{resource}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  to: {{toUser}}
  resource: {{resource}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    bru.setVar("party", testdata.Bot_Org.partyuuid);
    bru.setVar("toUser", testdata.Bot_person.partyuuid);
    bru.setVar("resource", testdata.resource_to_delegate.maskinporten_ressurs);
    
    var getTokenParameters = {
      auth_userId: testdata.Bot_Org.innehaver.userid,
      auth_partyId: testdata.Bot_Org.innehaver.partyid,
      auth_partyUuid: testdata.Bot_Org.innehaver.partyuuid,
      auth_ssn: testdata.Bot_Org.innehaver.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.sluttbrukerdelegationrequestwrite
    }
    
    
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    test("Person_A request for access on maskinporten resources to Org_user", function() {
      const data = res.getBody();
      
      expect(res.status).to.equal(400);
      expect(data.validationErrors[0].resource).to.include("Resource 'ttd-bruno-maskinporten-ressurs' is of type 'MaskinportenSchema' and cannot be requested");
     
    });
}

settings {
  encodeUrl: true
  timeout: 0
}

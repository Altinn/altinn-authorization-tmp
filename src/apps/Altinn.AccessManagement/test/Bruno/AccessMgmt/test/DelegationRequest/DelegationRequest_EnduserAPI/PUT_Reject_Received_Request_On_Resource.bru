meta {
  name: PUT_Reject_Received_Request_On_Resource
  type: http
  seq: 14
}

put {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/request/received/reject?party={{party}}&id={{resource2requestId}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  id: {{resource2requestId}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    bru.setVar("party", testdata.Bot_Org.partyuuid);
    
    var getTokenParameters = {
      auth_userId: testdata.Bot_Org.innehaver.userid,
      auth_partyId: testdata.Bot_Org.innehaver.partyid,
      auth_partyUuid: testdata.Bot_Org.innehaver.partyuuid,
      auth_ssn: testdata.Bot_Org.innehaver.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.portalEnduser
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    test("PUT_Reject_Received_Request_On_Resource", function() {
      expect(res.status).to.be.oneOf([200], "Expected 200 or 204 for reject request");
      
      // If we get 200 with body, verify it
      if(res.status === 200) {
        const data = res.getBody();
        if(data) {
          expect(data).to.have.property("status", "Rejected");
        }
      }
    });
}

settings {
  encodeUrl: true
  timeout: 0
}

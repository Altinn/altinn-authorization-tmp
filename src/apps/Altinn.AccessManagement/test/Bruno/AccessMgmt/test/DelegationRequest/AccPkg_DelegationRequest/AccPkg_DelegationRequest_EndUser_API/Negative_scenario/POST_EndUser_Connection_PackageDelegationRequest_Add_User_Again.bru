meta {
  name: POST_EndUser_Connection_PackageDelegationRequest_Add_User_Again
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections?party={{party}}&from={{party}}
  body: json
  auth: inherit
}

params:query {
  party: {{party}}
  from: {{party}}
}

body:json {
   {
    "personidentifier": "{{toPerson}}", // fnr or username
    "lastName": "{{toPersonLastName}}"
  }
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    
    bru.setVar("party", testdata.Bot_package_Org_B.partyuuid);
  
    bru.setVar("toPerson", testdata.Bot_package_person.pid);
    bru.setVar("toPersonLastName", testdata.Bot_package_person.lastname);
  
    
    var getTokenParameters = {
      auth_userId: testdata.Bot_package_Org_B.innehaver.userid,
      auth_partyId: testdata.Bot_package_Org_B.innehaver.partyid,
      auth_partyUuid: testdata.Bot_package_Org_B.innehaver.partyuuid,
      auth_ssn: testdata.Bot_package_Org_B.innehaver.pid,
      
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.portalEnduser
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
  
}

settings {
  encodeUrl: true
  timeout: 0
}

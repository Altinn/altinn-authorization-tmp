meta {
  name: GET_Resources_Which_User_has_received_app
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/request/received?party={{party}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    bru.setVar("party", testdata.Bot_Org_2.partyuuid);
  
    var getTokenParameters = {
      auth_userId: testdata.Bot_Org_2.styreleder.userid,
      auth_partyId: testdata.Bot_Org_2.styreleder.partyid,
      auth_partyUuid: testdata.Bot_Org_2.styreleder.partyuuid,
      auth_ssn: testdata.Bot_Org_2.styreleder.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.sluttbrukerdelegationrequestread
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token)
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
    test("GET received request for access on resources for privat person", function() {
      const data = res.getBody();
      expect(res.status).to.equal(200);
      expect(data).to.exist;
      expect(data).to.have.property("data");
      expect(data.data).to.be.an("array");
      if (data.data.length > 0) {
        const request = data.data[0];
        expect(request).to.have.property("id");
        expect(request).to.have.property("type", "resource");
        expect(request.resource).to.exist;
        expect(request.from).to.have.property("id", testdata.Bot_from_person.partyuuid);
        expect(request.to).to.have.property("id", testdata.Bot_Org_2.partyuuid);
      }
    });
}

settings {
  encodeUrl: true
  timeout: 0
}

meta {
  name: GET_status_of_Request_After_confirmed_from_user
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/serviceowner/delegationrequests/{{tilgangspakkeserviceowner_requestId}}/status
  body: none
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    
    
    var getTokenParameters = {
      auth_org: sharedtestdata.serviceOwners.ttd.org,
      auth_orgNo: sharedtestdata.serviceOwners.digdir.orgno,
      auth_tokenType: sharedtestdata.authTokenType.enterprise,
      auth_scopes: sharedtestdata.auth_scopes.serviceownerDelegationRequestRead
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
      
      test("GET status of POST response based on requestId", function() {
        const data = res.getBody();
        
        expect(res.status).to.equal(200);
      
        expect(data).to.exist;
        const actualStatus = typeof data === "string" ? data : String(data);
        expect(actualStatus).to.equal("Pending");
        
      });
}

settings {
  encodeUrl: true
  timeout: 0
}

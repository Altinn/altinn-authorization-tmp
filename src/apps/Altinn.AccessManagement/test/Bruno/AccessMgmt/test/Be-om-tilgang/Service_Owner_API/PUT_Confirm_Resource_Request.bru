meta {
  name: PUT_Confirm_Resource_Request
  type: http
  seq: 7
}

put {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/request/draft/confirm?party={{party}}&id={{serviceowner_requestId}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  id: {{serviceowner_requestId}}
}

script:post-response {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.Bot_person_serviceowner.partyuuid);
  
  var getTokenParameters = {
    auth_userId: testdata.Bot_person_serviceowner.userid,
    auth_partyId: testdata.Bot_person_serviceowner.partyid,
    auth_partyUuid: testdata.Bot_person_serviceowner.partyuuid,
    auth_ssn: testdata.Bot_person_serviceowner.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
  
  test("Confirm request for access on resources from Org_user", function() {
    const data = res.getBody();
    
    expect(res.status).to.equal(200);
    expect(data).to.exist;
    expect(data.id).to.exist;
    expect(data).to.have.property("id");
  expect(data).to.have.property("status", "Pending");
  expect(data).to.have.property("type", "resource");
  
  // Resource check
  expect(data.resource).to.exist;
  expect(data.resource).to.have.property(
    "referenceId",
    "ttd-test-bruno-enkelttjeneste-privatperson-ressurs"
  );
  
  // From / To check
  expect(data.from).to.have.property("organizationIdentifier", testdata.Bot_Org.org_no);
  expect(data.to).to.have.property("personIdentifier", testdata.Bot_person.pid);
  
  // Save id for GET request
  bru.setVar("requestId", data.id);
    
  });
}



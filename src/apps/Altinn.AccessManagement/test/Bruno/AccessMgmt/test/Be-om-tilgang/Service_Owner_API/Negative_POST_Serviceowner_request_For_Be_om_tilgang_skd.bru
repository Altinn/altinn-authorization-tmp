meta {
  name: Negative_POST_Serviceowner_request_For_Be_om_tilgang_skd
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/serviceowner/delegationrequests
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  "from": "urn:altinn:person:identifier-no:{{from}}",
  "to": "urn:altinn:organization:identifier-no:{{toOrg}}",
  "resource": { 
    "referenceid": "{{resource}}"
  },
  "package": null
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("from", testdata.Bot_person_serviceowner.pid);
  bru.setVar("toOrg", testdata.Bot_Org_for_serviceowner.org_no);
  bru.setVar("resource", testdata.resource_to_delegate.skattetaten_ressurs);
  
  var getTokenParameters = {
    auth_org: sharedtestdata.serviceOwners.digdir.org,
    auth_orgNo: sharedtestdata.serviceOwners.digdir.orgno,
    auth_tokenType: sharedtestdata.authTokenType.enterprise,
    auth_scopes: sharedtestdata.auth_scopes.serviceownerDelegationRequestWrite
  }
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/be-om-tilgang/${bru.getEnvVar("tokenEnv")}.js`);
  

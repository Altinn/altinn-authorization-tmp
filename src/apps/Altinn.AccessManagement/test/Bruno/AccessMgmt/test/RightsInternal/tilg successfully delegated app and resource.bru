meta {
  name: tilg successfully delegated app and resource
  type: http
  seq: 41
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/internal/{{party}}/rights/delegation/received
  body: json
  auth: inherit
}

vars:pre-request {
  auth_tokenType: Personal
  auth_userId: 
  auth_partyId: 
  auth_ssn: 
  party: 
}

script:pre-request {
  const testdata = require(`./testdata/rights-delegations/${bru.getEnvVar("tokenEnv")}testdata.js`);
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  bru.setVar("party", testdata.randomUser.partyid);
  
  var getTokenParameters = {
    auth_userId: testdata.randomUser.userid,
    auth_partyId: testdata.randomUser.partyid,
    auth_partyUuid: testdata.randomUser.partyuuid,
    auth_ssn: testdata.randomUser.pid,
    scope: sharedtestdata.scopes.read,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.read
  }
    
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  
  bru.setVar("bearerToken",  token);
}

tests {
  test("person successfully delegated to a person", function() {
    const testdata = require(`./testdata/rights-delegations/${bru.getEnvVar("tokenEnv")}testdata.js`);
      const data = res.body;
    expect(res.status).to.equal(200);
  
  const appEntry = data.find(item =>
    item.resource.some(r => r.id === 'urn:altinn:org' && r.value === 'ttd') &&
    item.resource.some(r => r.id === 'urn:altinn:app' && r.value === testdata.app)
  );
  
  expect(appEntry, 'App entry should exist').to.exist;
  
  //Partyid
  expect(
    appEntry.from.some(f => f.id === 'urn:altinn:partyid' && f.value === testdata.org3.partyid.toString()),
    'App entry FROM should match'
  ).to.equal(true);
  
  //Userid
  expect(
    appEntry.to.some(t => t.id === 'urn:altinn:userid' && t.value === testdata.randomUser.userid.toString()),
    'App entry TO should match'
  ).to.equal(true);
  
  
  //Resourcename
  const resourceEntry = data.find(item =>
    item.resource.some(r => r.id === 'urn:altinn:resource' && r.value === 'devtest_gar_bruno-gar')
  );
  
  expect(resourceEntry, 'Resource entry should exist').to.exist;
  
  // Verify FROM (partyid)
  expect(
    resourceEntry.from.some(f => f.id === 'urn:altinn:partyid' && f.value === testdata.org3.partyid.toString()),
    'Resource entry FROM should match'
  ).to.equal(true);
  
  // Verify TO (userid)
  expect(
    resourceEntry.to.some(t => t.id === 'urn:altinn:userid' && t.value === testdata.randomUser.userid.toString()),
    'Resource entry TO should match'
  ).to.equal(true)
    });
    
}

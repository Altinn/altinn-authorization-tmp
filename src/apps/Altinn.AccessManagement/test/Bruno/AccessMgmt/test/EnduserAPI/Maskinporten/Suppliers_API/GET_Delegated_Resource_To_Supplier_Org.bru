meta {
  name: GET_Delegated_Resource_To_Supplier_Org
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/maskinportensuppliers/resources?party={{party}}&supplier={{supplier_orgno}}&resource={{resource}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  supplier: {{supplier_orgno}}
  resource: {{resource}}
}

script:pre-request {
  const testdata = require(`./testdata/maksinporten-delegation/${bru.getEnvVar("tokenEnv")}.js`);
    const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    
    bru.setVar("party", testdata.consumer_Org.partyuuid);
    bru.setVar("supplier_orgno", testdata.supplier_Org.orgno);
    bru.setVar("resource", testdata.resource_to_delegate.maskinporten_ressurs);
  
    
    var getTokenParameters = {
      auth_userId: testdata.consumer_Org.dagligleder.userid,
      auth_partyId: testdata.consumer_Org.dagligleder.partyid,
      auth_partyUuid: testdata.consumer_Org.dagligleder.partyuuid,
      auth_ssn: testdata.consumer_Org.dagligleder.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.portalEnduser
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token)
}

tests {
  const testdata = require(`./testdata/maksinporten-delegation/${bru.getEnvVar("tokenEnv")}.js`); 
  
  test("GET list av maskinporten resource which was delegated to supplier org from consumer org", function() {
    const data = res.getBody();
    expect(res.status).to.equal(200);
    expect(res.getBody()[0].resource.type.name)
      .to.equal("MaskinportenSchema");
  });
  
    expect(res.getBody()[0].permissions[0].from.type)
      .to.equal("Organisasjon");
     expect(res.getBody()[0].permissions[0].to.type)
      .to.equal("Organisasjon")
    expect(res.getBody()[0].permissions[0].role.code)
      .to.equal("supplier")
  
    expect(res.getBody()[0].permissions[0].from.organizationIdentifier).to.equal(testdata.consumer_Org.orgno)
  
    expect(res.getBody()[0].permissions[0].to.organizationIdentifier)
      .to.equal(testdata.supplier_Org.orgno)
  
}

settings {
  encodeUrl: true
  timeout: 0
}

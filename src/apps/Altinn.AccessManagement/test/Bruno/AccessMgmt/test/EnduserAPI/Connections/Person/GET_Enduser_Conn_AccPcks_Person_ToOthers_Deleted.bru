meta {
  name: GET_Enduser_Conn_AccPcks_Person_ToOthers_Deleted
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections/accesspackages?party={{party}}&from={{party}}&to={{toPerson}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  from: {{party}}
  to: {{toPerson}}
}

body:json {
   
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/person-accesspackage-delegation/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.vassen_riktig_tiger_as.partyuuid);
  bru.setVar("package", testdata.package_to_delegate.package_urn);
  bru.setVar("toPerson", testdata.vassen_riktig_tiger_as.person1.partyuuid);
  
  
  var getTokenParameters = {
    auth_userId: testdata.vassen_riktig_tiger_as.dagl.userid,
    auth_partyId: testdata.vassen_riktig_tiger_as.dagl.partyid,
    auth_partyUuid: testdata.vassen_riktig_tiger_as.dagl.partyuuid,
    auth_ssn: testdata.vassen_riktig_tiger_as.dagl.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken",  token);
}

tests {
  const testdata = require(`./testdata/person-accesspackage-delegation/${bru.getEnvVar("tokenEnv")}.js`);
  test("GET_Enduser_Conn_AccPcks_Person_ToOthers_Deleted", function() {
  
     const data = res.getBody();
    expect(res.status).to.equal(200);
    expect(data.data).to.be.empty;
  
  });
}

docs {

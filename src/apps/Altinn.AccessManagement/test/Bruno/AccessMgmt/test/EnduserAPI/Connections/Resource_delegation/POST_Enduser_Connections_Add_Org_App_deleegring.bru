meta {
  name: POST_Enduser_Connections_Add_Org_App_deleegring
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections?party={{party}}&from={{party}}&to={{toOrg}}
  body: json
  auth: inherit
}

params:query {
  party: {{party}}
  from: {{party}}
  to: {{toOrg}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/enkelttjenestedelegering/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.orgA_delegates.partyuuid);
  bru.setVar("toOrg", testdata.orgB_delegates.partyuuid);
  
  var getTokenParameters = {
    auth_userId: testdata.orgA_delegates.innehaver.userid,
    auth_partyId: testdata.orgA_delegates.innehaver.partyid,
    auth_partyUuid: testdata.orgA_delegates.innehaver.partyuuid,
    auth_ssn: testdata.orgA_delegates.innehaver.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken",  token);
}

tests {
  const testdata = require(`./testdata/enkelttjenestedelegering/${bru.getEnvVar("tokenEnv")}.js`);
  test("Add Org as rettighetshaver for App delegation", function() {
    const data = res.getBody();
    
    expect(res.status).to.equal(200);
    assert.isOk(data, "Expected response body to return created assignment");
    
    assert.equal(data.fromId, bru.getVar("party").toLowerCase());
    assert.equal(data.toId, testdata.orgB_delegates.partyuuid.toLowerCase());
    assert.equal(data.roleId, "42cae370-2dc1-4fdc-9c67-c2f4b0f0f829"); // rettighetshaver uuid
    
  });
}

docs {
  Lager connection til person
}

meta {
  name: GET_DelegationCheck_For_App
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections/resources/delegationcheck?party={{party}}&resource={{resource}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  resource: {{resource}}
}

headers {
  Accept: application/json
  Content-Type: application/json
}

vars:pre-request {
  party: 08cb10ee-4f3d-461a-8b11-a6604fdf2cc2
  resource: ttd-test-enkeltjeneste-ressurs-at22
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/enkelttjenestedelegering/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.orgA_delegates.partyuuid);
  bru.setVar("to", testdata.orgB_delegates.partyuuid);
  bru.setVar("resource", testdata.resource_to_delegate.app_id);
  
  var getTokenParameters = {
    auth_userId: testdata.orgA_delegates.innehaver.userid,
    auth_partyId: testdata.orgA_delegates.innehaver.partyid,
    auth_partyUuid: testdata.orgA_delegates.innehaver.partyuuid,
    auth_ssn: testdata.orgA_delegates.innehaver.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken",  token);
}

script:post-response {
  
  
}

tests {
  const testdata = require(`./testdata/enkelttjenestedelegering/${bru.getEnvVar("tokenEnv")}.js`);
  
  test("DelegationCheck for party has access to App to delegate App", function() {
    const data = res.getBody();
    
  expect(data.resource).to.exist;
  expect(data.resource.refId).to.equal(testdata.resource_to_delegate.app_id);
  const allowedActions = ["read", "write", "delete", "instantiate"];
  
  // Verify allowed actions
  allowedActions.forEach(action => {
  
    const right = data.rights.find(r => r.right.action.value === action);
  
    expect(right, `${action} right missing`).to.exist;
    expect(right.result, `${action} should be allowed`).to.equal(true);
    expect(right.reasonCodes).to.include("RoleAccess");
  
  });
  
  // Verify missing delegation access action
  //const missingAccess = data.rights.find(r => r.right.action.value === "complete");
  
  //expect(missingAccess, "complete action should exist").to.exist;
  //expect(missingAccess.result).to.equal(false);
  //expect(missingAccess.reasonCodes).to.include("MissingDelegationAccess");
  
  // Verify resource on all rights
  data.rights.forEach(r => {
  
    expect(
      r.right.resource.some(res => res.value === "app_ttd_test-bruno-app-for-delegation"),
      "right should belong to correct resource"
    ).to.equal(true);
  })
  
  });
}

settings {
  encodeUrl: true
  timeout: 0
}

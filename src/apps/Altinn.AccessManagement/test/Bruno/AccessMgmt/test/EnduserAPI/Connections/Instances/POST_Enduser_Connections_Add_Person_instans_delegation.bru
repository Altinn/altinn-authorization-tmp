meta {
  name: POST_Enduser_Connections_Add_Person_instans_delegation
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections?party={{party}}&from={{party}}
  body: json
  auth: inherit
}

params:query {
  party: {{party}}
  from: {{party}}
}

body:json {
  {
      "personidentifier": "{{toPerson}}",
      "lastName": "{{toPersonLastName}}"
    }
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    const testdata = require(`./testdata/enduser_instans-delegation/${bru.getEnvVar("tokenEnv")}.js`);
    
    bru.setVar("toPerson", testdata.instance_to_user.user_2.pid);
    bru.setVar("toPersonLastName", testdata.instance_to_user.user_2.lastname);
    bru.setVar("party", testdata.instance_from_user.user_1.partyUuid);
    
    var getTokenParameters = {
      auth_userId: testdata.instance_from_user.user_1.userId,
      auth_partyId: testdata.instance_from_user.user_1.partyId,
      auth_partyUuid: testdata.instance_from_user.user_1.partyUuid,
      auth_ssn: testdata.instance_from_user.user_1.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.portalEnduser
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token);
}

tests {
  const testdata = require(`./testdata/enduser_instans-delegation/${bru.getEnvVar("tokenEnv")}.js`);
    test("POST_Enduser_Connections_Add_Person_For_instans_delegation", function() {
      const data = res.getBody();
  
      expect(res.status).to.equal(200);
      assert.isOk(data, "Expected response body to return created connection");
  
      assert.property(data, "id", "Expected response to have an id");
      assert.property(data, "fromId", "Expected response to have fromId");
      assert.property(data, "toId", "Expected response to have toId");
      assert.property(data, "roleId", "Expected response to have roleId");
  
      assert.equal(data.fromId, bru.getVar("party").toLowerCase(), "Expected fromId to match user_1 partyUuid");
      assert.equal(data.toId, testdata.instance_to_user.user_2.partyUuid.toLowerCase(), "Expected toId to match user_2 partyUuid");
      assert.equal(data.roleId, "42cae370-2dc1-4fdc-9c67-c2f4b0f0f829", "Expected roleId to be rettighetshaver");
    });
}

settings {
  encodeUrl: true
  timeout: 0
}

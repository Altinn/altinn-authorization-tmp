meta {
  name: Negative_POST_add_Supplier_Org_With_Tilgangstyrrer
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/maskinportensuppliers?party={{party}}&supplier={{orgno}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  supplier: {{orgno}}
}

script:pre-request {
  const testdata = require(`./testdata/maksinporten-delegation/${bru.getEnvVar("tokenEnv")}.js`);
    const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    
    bru.setVar("party", testdata.consumer_Org.partyuuid);
    bru.setVar("orgno", testdata.supplier_Org.orgno);
    
    var getTokenParameters = {
      auth_userId: testdata.consumer_Org.tilgangstyrrer_consumer_org.userid,
      auth_partyId: testdata.consumer_Org.tilgangstyrrer_consumer_org.partyid,
      auth_partyUuid: testdata.consumer_Org.tilgangstyrrer_consumer_org.partyuuid,
      auth_ssn: testdata.consumer_Org.tilgangstyrrer_consumer_org.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.portalEnduser
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token)
}

tests {
  const testdata = require(`./testdata/maksinporten-delegation/${bru.getEnvVar("tokenEnv")}.js`); 
  test("Add maskinporten supplier organization with Tilgangstyyring role", function() {
     const data = res.getBody();
    expect(res.status).to.equal(403);
     });
     
   
}

settings {
  encodeUrl: true
  timeout: 0
}

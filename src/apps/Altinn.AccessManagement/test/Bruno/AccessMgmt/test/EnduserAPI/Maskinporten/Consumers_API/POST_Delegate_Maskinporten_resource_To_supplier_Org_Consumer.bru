meta {
  name: POST_Delegate_Maskinporten_resource_To_supplier_Org_Consumer
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/maskinportensuppliers/resources?party={{party}}&supplier={{orgno}}&resource={{resource}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  supplier: {{orgno}}
  resource: {{resource}}
}

script:pre-request {
  const testdata = require(`./testdata/maksinporten-delegation/${bru.getEnvVar("tokenEnv")}.js`);
    const sharedtestdata = require(`./testdata/sharedtestdata.js`);
    
    bru.setVar("party", testdata.consumer_Org2.partyuuid);
    bru.setVar("orgno", testdata.supplier_Org2.orgno);
    bru.setVar("resource", testdata.resource_to_delegate.maskinporten_ressurs);
    
    var getTokenParameters = {
      auth_userId: testdata.consumer_Org2.bostyrer.userid,
      auth_partyId: testdata.consumer_Org2.bostyrer.partyid,
      auth_partyUuid: testdata.consumer_Org2.bostyrer.partyuuid,
      auth_ssn: testdata.consumer_Org2.bostyrer.pid,
      auth_tokenType: sharedtestdata.authTokenType.personal,
      auth_scopes: sharedtestdata.auth_scopes.portalEnduser
    }
    
    const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
    const token = await testTokenGenerator.getToken(getTokenParameters);
    bru.setVar("bearerToken", token)
}

tests {
  const testdata = require(`./testdata/maksinporten-delegation/${bru.getEnvVar("tokenEnv")}.js`); 
  
  test("Delegate maskinporten resource to supplier org", function() {
    const data = res.getBody();
    expect(res.status).to.equal(200);
     expect(res.getBody()).to.equal(true);
     });
}

settings {
  encodeUrl: true
  timeout: 0
}

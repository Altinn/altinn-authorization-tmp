meta {
  name: GET_Delegated_Enketltjeneste_App__FromOthers
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections/resources?party={{to}}&to={{to}}&from={{party}}&resource={{resource}}
  body: none
  auth: inherit
}

params:query {
  party: {{to}}
  to: {{to}}
  from: {{party}}
  resource: {{resource}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/enkelttjenestedelegering/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.orgA_delegates.partyuuid);
  bru.setVar("to", testdata.orgB_delegates.partyuuid);
  bru.setVar("resource", testdata.resource_to_delegate.app_id);
  
  var getTokenParameters = {
    auth_userId: testdata.orgB_delegates.bostyrer.userid,
    auth_partyId: testdata.orgB_delegates.bostyrer.partyid,
    auth_partyUuid: testdata.orgB_delegates.bostyrer.partyuuid,
    auth_ssn: testdata.orgB_delegates.bostyrer.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.enduserSystemFromOthersRead
  }
  
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken",  token);
}

tests {
  test("GET resources which are delegated from Privat_users : FromOthers ", function() {
    
  const testdata = require(`./testdata/enkelttjenestedelegering/${bru.getEnvVar("tokenEnv")}.js`);
    
    const data = res.getBody();
    expect(res.status).to.equal(200);
    
  
  //  Find the record for the expected resource name
  const record = data.find(item =>
    item.resource.name === "test-bruno-app-for-delegation"
  );
  
  expect(record, "Resource should exist").to.exist;
  
  // Check FROM partyuuid
  expect(record.permissions[0].from).to.have.property(
    'id',
    testdata.orgA_delegates.partyuuid.toLowerCase()
  );
  
  // Check TO partyuuid
  expect(record.permissions[0].to).to.have.property(
    'id',
    testdata.orgB_delegates.partyuuid.toLowerCase()
  );
  
    
  });
}

settings {
  encodeUrl: true
  timeout: 0
}

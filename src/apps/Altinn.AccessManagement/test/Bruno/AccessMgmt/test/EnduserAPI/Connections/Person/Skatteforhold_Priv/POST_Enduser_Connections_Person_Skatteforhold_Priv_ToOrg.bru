meta {
  name: POST_Enduser_Connections_Person_Skatteforhold_Priv_ToOrg
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/enduser/connections?party={{party}}&from={{party}}&to={{toOrg}}
  body: none
  auth: inherit
}

params:query {
  party: {{party}}
  from: {{party}}
  to: {{toOrg}}
}

script:pre-request {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./testdata/person-accesspackage-delegation/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("party", testdata.privat_person_C.partyuuid);
  bru.setVar("toOrg", testdata.virksomhet_A.partyuuid);
  
  var getTokenParameters = {
    auth_userId: testdata.privat_person_C.userid,
    auth_partyId: testdata.privat_person_C.partyid,
    auth_partyUuid: testdata.privat_person_C.partyuuid,
    auth_ssn: testdata.privat_person_C.pid,
    auth_tokenType: sharedtestdata.authTokenType.personal,
    auth_scopes: sharedtestdata.auth_scopes.portalEnduser
  }
  
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken",  token);
}

docs {
  Lager connection til organisasjon
}

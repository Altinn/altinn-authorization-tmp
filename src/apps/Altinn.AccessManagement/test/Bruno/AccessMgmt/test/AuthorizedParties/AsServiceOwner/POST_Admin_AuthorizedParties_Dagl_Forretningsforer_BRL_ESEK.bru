meta {
  name: POST_Admin_AuthorizedParties_Dagl_Forretningsforer_BRL_ESEK
  type: http
  seq: 19
}

post {
  url: {{baseUrl}}/accessmanagement/api/v1/resourceowner/authorizedparties?includeAltinn2=true&includeAltinn3=true&includeRoles=true&includeAccessPackages=true&includeResources=true&includeInstances=true&includePartiesViaKeyRoles=true&includeSubParties=true&includeInactiveParties=true&anyOfResourceIds=devtest_gar_bruno_forretningsforer_eiendom
  body: json
  auth: inherit
}

params:query {
  includeAltinn2: true
  includeAltinn3: true
  includeRoles: true
  includeAccessPackages: true
  includeResources: true
  includeInstances: true
  includePartiesViaKeyRoles: true
  includeSubParties: true
  includeInactiveParties: true
  anyOfResourceIds: devtest_gar_bruno_forretningsforer_eiendom
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "type": "urn:altinn:person:identifier-no",
    "value": "{{personId}}"
  }
}

script:pre-request {
  
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./test/AuthorizedParties/testdata/${bru.getEnvVar("tokenEnv")}.js`);
  
  bru.setVar("requestName", "POST_Admin_AuthorizedParties_Dagl_Forretningsforer_BRL_ESEK");
  bru.setVar("personId", testdata.forretningsforerNonfigurativEmosjonellPuma.dagligleder.pid);
  
  var getTokenParameters = {
    auth_org: sharedtestdata.serviceOwners.digdir.org,
    auth_orgNo: sharedtestdata.serviceOwners.digdir.orgno,
    auth_tokenType: sharedtestdata.authTokenType.enterprise,
    auth_scopes: sharedtestdata.auth_scopes.authorizedPartiesAdmin
  }
  
  const testTokenGenerator = require(`./TestToolsTokenGenerator.js`);
  const token = await testTokenGenerator.getToken(getTokenParameters);
  bru.setVar("bearerToken", token);
}

tests {
  const sharedtestdata = require(`./testdata/sharedtestdata.js`);
  const testdata = require(`./test/AuthorizedParties/testdata/${bru.getEnvVar("tokenEnv")}.js`);
  const body = res.getBody();
  const requestName = bru.getVar("requestName");
  
  test(requestName + "|HttpStatus.OK", function() {
    expect(res.status).to.equal(200);
  });
  
  test(requestName + "|VerifyResponse", function() {
    const allowedParentUnitTypes = ["ESEK", "BRL"];
    const allowedAccessPackages = ["forretningsforer-eiendom"];
  
    /**
     * Validate access packages for any party (parent or subunit)
     */
    function validateAccessPackages(party, path) {
      expect(
        party.authorizedAccessPackages,
        `${path} authorizedAccessPackages is not an array`
      ).to.be.an("array");
  
      expect(
        party.authorizedAccessPackages,
        `${path} has invalid authorizedAccessPackages`
      ).to.have.members(allowedAccessPackages);
    }
  
    /**
     * Validate a parent party and recurse into subunits
     */
    function validateParentParty(party, path) {
      // ✅ Parent unitType validation
      expect(
        allowedParentUnitTypes.includes(party.unitType),
        `${path} has invalid parent unitType: ${party.unitType}`
      ).to.be.true;
  
      // ✅ Access packages (parent)
      validateAccessPackages(party, path);
  
      // ✅ Subunits: access packages only (no unitType restriction)
      if (Array.isArray(party.subunits)) {
        party.subunits.forEach((subunit, index) => {
          const subPath = `${path}.subunits[${index}]`;
          validateAccessPackages(subunit, subPath);
        });
      }
    }
  
    // Run validation for all top-level parties
    body.forEach((party, index) => {
      validateParentParty(party, `response[${index}]`);
    });
  });
  
}

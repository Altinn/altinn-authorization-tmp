<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <XUnitVersion>v3</XUnitVersion>
        <!-- This is a shared test-helper library, not a runnable test project.
             Override the inherited IsTestProject=true so `dotnet test` does
             not try to execute it (which fails under MTP when 0 tests are
             discovered). -->
        <IsTestProject>false</IsTestProject>
        <IsTestLibrary>true</IsTestLibrary>
        <!-- Link the shared PostgreSQL test engine (src/testing/PostgresTestEngine.cs). -->
        <IncludePostgresTestEngine>true</IncludePostgresTestEngine>
        <!-- Link the shared auth/token test doubles (src/testing/AuthTestInfra/*.cs).
             TestUtils is the single compile site for the AccessManagement test graph;
             every AccessManagement test project references it, so they all see the
             shared Altinn.Authorization.Testing types without source-linking them again. -->
        <IncludeAuthTestInfra>true</IncludeAuthTestInfra>
    </PropertyGroup>

    <ItemGroup>
        <None Include="Data\UserProfile\**">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Testcontainers.PostgreSql" />
        <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
        <PackageReference Include="Moq" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Altinn.AccessManagement\Altinn.AccessManagement.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Update="Data\AuthorizedParties\SBLBridge\authorizedparties_u20049134.json">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="Data\AuthorizedParties\SBLBridge\authorizedparties_u20049963.json">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="Data\AuthorizedParties\SBLBridge\authorizedparties_u20096763.json">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="Data\AuthorizedParties\SBLBridge\authorizedparties_u20198981.json">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
    </ItemGroup>

</Project>

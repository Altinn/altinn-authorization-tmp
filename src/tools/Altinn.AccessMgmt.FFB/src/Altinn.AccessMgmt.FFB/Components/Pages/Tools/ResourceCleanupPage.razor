@page "/tools/resource-cleanup"
@using Altinn.AccessMgmt.FFB.Jobs
@using Altinn.AccessMgmt.FFB.Jobs.Models
@using Altinn.AccessMgmt.FFB.Services
@using Altinn.AccessMgmt.PersistenceEF.Constants
@using Altinn.AccessMgmt.PersistenceEF.Models
@inject IJobRunner JobRunner
@inject IJobRunStore RunStore
@inject IEnvironmentDbContextFactory EnvFactory
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>Resource Cleanup</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Resource Cleanup</MudText>
<MudText Typo="Typo.body1" Class="mb-6 mud-text-secondary">
    Finner og sletter <code>AssignmentResource</code>-rader for en gitt <code>resource.refid</code>.
    Kan også fjerne tomme <code>Assignment</code>-rader (de uten delegations, andre resources, packages eller instances).
    Kjøres i en transaksjon med full audit-kontekst.
</MudText>

@* ── Input panel ──────────────────────────────────────────────────────────── *@
<MudPaper Elevation="1" Class="pa-4 mb-6">
    <MudText Typo="Typo.h6" Class="mb-3">Parametere</MudText>

    <MudGrid Spacing="3">
        @* Resource RefId *@
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_resourceRefId"
                          Label="Resource RefId"
                          Variant="Variant.Outlined"
                          HelperText="F.eks. app_ttd_jks-testapp"
                          Immediate="true" />
        </MudItem>

        @* Operation ID *@
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_operationId"
                          Label="Operation ID (valgfri)"
                          Variant="Variant.Outlined"
                          HelperText="Sak-ID eller annen referanse, f.eks. CAS-99028-W1N4F8"
                          Immediate="true" />
        </MudItem>

        @* System account *@
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_systemAccountId"
                       Label="System-konto (changed_by)"
                       Variant="Variant.Outlined"
                       HelperText="Brukes som changed_by i audit-kontekst">
                @foreach (var entity in SystemEntities)
                {
                    var e = entity;
                    <MudSelectItem Value="@e.Id">@e.Entity.RefId — @e.Entity.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @* Remove empty assignments *@
        <MudItem xs="12" sm="6" Class="d-flex align-center">
            <MudCheckBox @bind-Value="_removeEmptyAssignments"
                         Color="Color.Warning"
                         Label="Fjern tomme Assignment-rader (ingen delegations/resources/packages/instances)" />
        </MudItem>

        @* Environment *@
        <MudItem xs="12">
            <MudText Typo="Typo.body2" Class="mb-2 mud-text-secondary">Miljø:</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                @foreach (var env in EnvFactory.Environments)
                {
                    var envName = env;
                    var configured = EnvFactory.IsConfigured(envName);
                    <MudCheckBox @bind-Value="_selected[envName]"
                                 Label="@envName"
                                 Disabled="@(!configured)"
                                 Color="Color.Primary" />
                }
            </MudStack>
        </MudItem>

        @* Buttons *@
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Search"
                       Disabled="@(!CanRun)"
                       OnClick="StartPreview">
                Preview
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ── Runs ─────────────────────────────────────────────────────────────────── *@
@if (_runs.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mb-3">Kjøringer</MudText>
    @foreach (var run in _runs)
    {
        <JobRunCard Run="@run">
            <ExtraActions>
                @if (run.Status == JobStatus.Completed &&
                     run.SqlOutput.Count > 0 &&
                     run.JobName == ResourceCleanupJob.JobName)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               OnClick="@(() => ConfirmAndExecute(run))">
                        Kjør SQL (@run.SqlOutput.Count statements)
                    </MudButton>
                }
            </ExtraActions>
        </JobRunCard>
    }
}

@code {
    private static readonly IReadOnlyList<ConstantDefinition<Entity>> SystemEntities =
        SystemEntityConstants.AllEntities()
            .OrderBy(e => e.Entity.RefId)
            .ToList();

    private readonly Dictionary<string, bool> _selected = new();
    private readonly HashSet<Guid> _subscribed = [];

    private string _resourceRefId = "";
    private string _operationId = "";
    private Guid _systemAccountId = SystemEntityConstants.DBA.Id;
    private bool _removeEmptyAssignments = true;
    private List<JobRun> _runs = [];

    protected override void OnInitialized()
    {
        foreach (var env in EnvFactory.Environments)
            _selected[env] = false;

        RefreshRuns();
    }

    private void StartPreview()
    {
        var opts = new ResourceCleanupOptions(
            ResourceRefId: _resourceRefId.Trim(),
            SystemAccountId: _systemAccountId,
            OperationId: _operationId.Trim(),
            RemoveEmptyAssignments: _removeEmptyAssignments);

        foreach (var (env, selected) in _selected)
        {
            if (!selected) continue;
            var run = JobRunner.StartResourceCleanup(env, opts);
            Subscribe(run);
            _runs.Insert(0, run);
        }

        StateHasChanged();
    }

    private async Task ConfirmAndExecute(JobRun previewRun)
    {
        var arCount = previewRun.SqlOutput.Count(s => s.Contains("assignmentresource"));
        var aCount = previewRun.SqlOutput.Count(s => s.Contains("\"assignment\""));

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText,
                $"Dette vil kjøre {previewRun.SqlOutput.Count} SQL-statements mot {previewRun.Environment} i en transaksjon.\n" +
                $"Sletter AssignmentResource-rader: ~{arCount}, Assignment-rader: ~{aCount}.\nKan ikke angres." },
            { x => x.ButtonText, "Kjør SQL" },
            { x => x.Color, Color.Error },
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Bekreft sletting", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var run = JobRunner.StartResourceCleanupExecute(previewRun.Id, previewRun.Environment);
            Subscribe(run);
            _runs.Insert(0, run);
            StateHasChanged();
        }
    }

    private void Subscribe(JobRun run)
    {
        if (_subscribed.Add(run.Id))
            run.OnUpdated += () => InvokeAsync(RefreshAndRender);
    }

    private void RefreshRuns()
    {
        var preview = RunStore.GetForJob(ResourceCleanupJob.JobName).ToList();
        var execute = RunStore.GetForJob($"{ResourceCleanupJob.JobName}:Execute").ToList();
        _runs = preview.Concat(execute)
            .OrderByDescending(r => r.StartedAt)
            .ToList();

        foreach (var run in _runs)
            Subscribe(run);
    }

    private void RefreshAndRender()
    {
        RefreshRuns();
        StateHasChanged();
    }

    private bool CanRun =>
        !string.IsNullOrWhiteSpace(_resourceRefId) &&
        _selected.Values.Any(v => v);

    public void Dispose() { }
}

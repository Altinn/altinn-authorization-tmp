@page "/"

<PageTitle>Hjem – Access Management</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">FFB — Access Management Toolbox</MudText>
<MudText Typo="Typo.body1" Class="mb-8 mud-text-secondary">
    Intern administrasjonsverktøy for Altinn 3 Access Management-teamet.
    Kjøres lokalt ved siden av API-et via <code>dotnet run --project *.AppHost</code>.
    Aktiv database velges i nedtrekksmenyen øverst til høyre.
</MudText>

<MudGrid Spacing="4">

    @* ── Verktøy + Jobber ─────────────────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">Verktøy</MudText>
            <MudDivider Class="my-2" />
            <MudStack Spacing="3">
                @ToolRow("/entity-search",        Icons.Material.Filled.ManageSearch,   "Entity-søk",         "Søk på entities via RefId, navn eller ID direkte mot databasen.")
                @ToolRow("/tools/tables",          Icons.Material.Filled.TableChart,      "Tabeller",           "Radantall og grupperingsanalyse for alle tabeller i skjemaet.")
                @ToolRow("/tools/connection-query",Icons.Material.Filled.AccountTree,     "Connection Query",   "Kjør forhåndsdefinerte EF-spørringer på tvers av tabeller.")
                @ToolRow("/tools/outbox",          Icons.Material.Filled.Outbox,          "Outbox",             "Overvåk outbox-meldinger — se pending, prosesserte og feilede.")
                @ToolRow("/tools/constants-check", Icons.Material.Filled.FactCheck,       "Constants Check",    "Sammenligner hardkodede konstanter i kode mot faktisk DB-innhold. Fikser avvik med INSERT/UPDATE/DELETE.")
                @ToolRow("/tools/resource-cleanup",Icons.Material.Filled.DeleteSweep,     "Resource Cleanup",   "Finn og rydd opp foreldreløse resource-rader basert på et RefId-prefix.")
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">Bakgrunnsjobber</MudText>
            <MudDivider Class="my-2" />
            <MudStack Spacing="3">
                @ToolRow("/jobs/runs",            Icons.Material.Filled.PlayCircle,      "Kjøringer",           "Sanntidsoversikt over alle aktive og avsluttede jobbkjøringer.")
                @ToolRow("/jobs/assignment-sync", Icons.Material.Filled.CompareArrows,   "Assignment Sync",     "To-pass diff mellom AccessMgmt og Register. Genererer INSERT/DELETE SQL for assignments.")
                @ToolRow("/jobs/entity-sync",     Icons.Material.Filled.People,          "Entity Sync",         "To-pass diff for entities. Genererer korrigeringsskript mot Register.")
                @ToolRow("/jobs/ingest-cleanup",  Icons.Material.Filled.CleaningServices,"Ingest Cleanup",      "Identifiserer stale tabeller i ingest-skjemaet. Genererer og kan kjøre DROP-statements.")
                @ToolRow("/jobs/history-cleanup", Icons.Material.Filled.History,         "History Cleanup",     "Slår sammen og rydder utløpte historikkrader (audit_validto IS NOT NULL).")
                @ToolRow("/jobs/schedules",       Icons.Material.Filled.Schedule,        "Planlagte kjøringer", "Cron-baserte planer konfigurert i appsettings.json. Kjør manuelt eller se neste tidspunkt.")
            </MudStack>
        </MudPaper>
    </MudItem>

    @* ── Utviklerguide ────────────────────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">Legge til et nytt verktøy</MudText>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                Et verktøy er en vanlig Blazor-side med direkte DB-tilgang via EF Core.
            </MudText>
            <ol class="ffb-guide">
                <li>
                    Opprett <code>Components/Pages/Tools/MinSide.razor</code><br />
                    med <code>@@page "/tools/min-side"</code>
                </li>
                <li>
                    Bruk disse to injeksjonene for DB-tilgang:
                    <pre class="ffb-pre">@@inject IEnvironmentDbContextFactory DbFactory
@@inject EnvironmentState EnvState

using var db = DbFactory.CreateContext(EnvState.Current);</pre>
                </li>
                <li>Legg til nav-lenke i <code>Components/Layout/NavMenu.razor</code> under «Verktøy».</li>
            </ol>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">Legge til en ny bakgrunnsjobb</MudText>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                Jobber kjøres på bakgrunnstråder med live logg-output. Bruk <code>DuoRepo</code>
                for Dapper-spørringer mot AccessMgmt og/eller Register.
            </MudText>
            <ol class="ffb-guide">
                <li>
                    Opprett <code>Jobs/MinNyJob.cs</code>:
                    <pre class="ffb-pre">public static class MinNyJob
{
    public const string JobName = "MinNyJob";

    public static async Task RunAsync(
        DuoRepo repo, JobRun run,
        MinNyJobOptions opts, CancellationToken ct = default)
    {
        run.AddLog("Starter...");
        var rows = await repo.QueryAccAsync&lt;MyDto&gt;(sql, ct: ct);
        run.AddSql(rows.Select(r => $"-- {r.Id}"));
    }
}</pre>
                </li>
                <li>
                    Legg til <code>StartMinNyJob(...)</code> i <code>IJobRunner</code>
                    og implementer i <code>JobRunner.cs</code> via <code>FireAndForget</code>.
                </li>
                <li>
                    Opprett <code>Components/Pages/Jobs/MinNyJob.razor</code>.
                    Følg mønsteret fra <code>EntitySync.razor</code> (start-panel + <code>&lt;JobRunCard&gt;</code>).
                </li>
                <li>Legg til nav-lenke i <code>NavMenu.razor</code> under «Jobber».</li>
                <li>
                    <em>Valgfritt — planlegging:</em> Legg til konstant i <code>JobTypes</code>
                    (<code>Config/JobSchedulesConfig.cs</code>) og en <code>case</code> i
                    <code>JobSchedulerService.FireSchedule</code>.
                </li>
            </ol>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.overline" Class="mud-text-secondary">Konfigurasjon</MudText>
            <MudDivider Class="my-2" />
            <MudStack Spacing="2">
                <MudText Typo="Typo.body2">
                    <strong>Miljøer</strong> — legg til connection strings under
                    <code>Environments[].AccessMgmt</code> og <code>.Register</code> i
                    <code>appsettings.json</code>. Ukonfigurerte miljøer vises som grå i UI.
                </MudText>
                <MudText Typo="Typo.body2">
                    <strong>Planlagte jobber</strong> — konfigureres under
                    <code>JobSchedules.Schedules</code>. Bruk «Generer konfig»-knappen
                    på jobb-siden for å lage et ferdig JSON-snippet.
                </MudText>
                <MudText Typo="Typo.body2">
                    <strong>Telegram-varsler</strong> — konfigureres under
                    <code>Notifications.BotToken</code> og <code>.ChatId</code>.
                    Sendes ved jobstart, fullføring og feil.
                </MudText>
            </MudStack>
        </MudPaper>
    </MudItem>

</MudGrid>

<style>
    .ffb-guide {
        padding-left: 1.2rem;
        margin: 0;
    }
    .ffb-guide li {
        font-size: 0.875rem;
        margin-bottom: 0.8rem;
        line-height: 1.6;
    }
    .ffb-pre {
        background: rgba(0, 0, 0, 0.06);
        border-radius: 4px;
        padding: 0.5rem 0.75rem;
        margin: 0.35rem 0 0;
        font-size: 0.76rem;
        font-family: monospace;
        overflow-x: auto;
        white-space: pre;
    }
</style>

@code {
    private RenderFragment ToolRow(string href, string icon, string label, string description) =>
        @<MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
            <MudIcon Icon="@icon" Size="Size.Small" Class="mt-1 mud-text-secondary" />
            <div>
                <MudLink Href="@href" Typo="Typo.body2">@label</MudLink>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@description</MudText>
            </div>
        </MudStack>;
}

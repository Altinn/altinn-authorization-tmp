@page "/jobs/history-cleanup"
@using Altinn.AccessMgmt.FFB.Jobs
@using Altinn.AccessMgmt.FFB.Jobs.Models
@using Altinn.AccessMgmt.FFB.Config
@using Altinn.AccessMgmt.FFB.Services
@inject IJobRunner JobRunner
@inject IJobRunStore RunStore
@inject IEnvironmentDbContextFactory EnvFactory
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>History Cleanup</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">History Cleanup</MudText>
<MudText Typo="Typo.body1" Class="mb-6 mud-text-secondary">
    Leser <code>dbo_history</code>-tabeller og finner overflødige versjoner: påfølgende rader der
    alle datafelter er identiske slås sammen (eldste <code>validFrom</code>, nyeste <code>validTo</code>).
    Rader med null varighet (<code>validFrom = validTo</code>) slettes direkte.
</MudText>

@* ── Start panel ──────────────────────────────────────────────────────────── *@
<MudPaper Elevation="1" Class="pa-4 mb-6">
    <MudText Typo="Typo.h6" Class="mb-3">Start ny kjøring</MudText>

    <MudGrid>
        <MudItem xs="12">
            <MudText Typo="Typo.body2" Class="mb-2 mud-text-secondary">Kjør på miljø:</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2" Class="mb-2">
                @foreach (var env in EnvFactory.Environments)
                {
                    var envName = env;
                    var configured = EnvFactory.IsConfigured(envName);
                    <MudCheckBox @bind-Value="_selected[envName]"
                                 Label="@envName"
                                 Disabled="@(!configured)"
                                 Color="Color.Primary" />
                }
            </MudStack>
        </MudItem>

        <MudItem xs="12">
            <MudText Typo="Typo.body2" Class="mb-1 mud-text-secondary">Tabeller:</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                @foreach (var key in HistoryCleanupJob.KnownTables.Keys)
                {
                    var k = key;
                    var cfg = HistoryCleanupJob.KnownTables[k];
                    <MudCheckBox @bind-Value="_selectedTables[k]"
                                 Color="Color.Primary">
                        @k
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">(@cfg.TableName)</MudText>
                    </MudCheckBox>
                }
            </MudStack>
        </MudItem>

        <MudItem xs="12">
            <MudCheckBox @bind-Value="_executeImmediately"
                         Color="Color.Error"
                         Label="Kjør SQL umiddelbart (uten forhåndsvisning)" />
        </MudItem>

        @if (_executeImmediately)
        {
            <MudItem xs="12">
                <MudAlert Severity="Severity.Warning" Dense="true">
                    DELETE- og UPDATE-statements vil kjøres uten bekreftelsesdialog.
                </MudAlert>
            </MudItem>
        }

        <MudItem xs="12">
            <MudButton Variant="Variant.Filled"
                       Color="@(_executeImmediately ? Color.Error : Color.Primary)"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       Disabled="@(!AnySelected)"
                       OnClick="StartJobs">
                @(_executeImmediately ? "Start og kjør SQL" : "Start (generer SQL)")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Class="ml-2"
                       StartIcon="@Icons.Material.Filled.Schedule"
                       Disabled="@(!AnySelected)"
                       OnClick="OpenScheduleDialog">
                Generer konfig
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ── Runs ─────────────────────────────────────────────────────────────────── *@
@if (_runs.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mb-3">Kjøringer</MudText>
    @foreach (var run in _runs)
    {
        <JobRunCard Run="@run" OnChanged="@RefreshAndRender">
            <ExtraActions>
                @if (run.Status == JobStatus.Completed &&
                     run.SqlOutput.Count > 0 &&
                     run.JobName == HistoryCleanupJob.JobName)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="@(() => ConfirmAndExecute(run))">
                        Kjør SQL (@run.SqlOutput.Count statements)
                    </MudButton>
                }
            </ExtraActions>
        </JobRunCard>
    }
}

@code {
    private readonly Dictionary<string, bool> _selected = new();
    private readonly Dictionary<string, bool> _selectedTables =
        HistoryCleanupJob.KnownTables.Keys.ToDictionary(k => k, _ => true);
    private readonly HashSet<Guid> _subscribed = [];
    private bool _executeImmediately;
    private List<JobRun> _runs = [];

    protected override void OnInitialized()
    {
        foreach (var env in EnvFactory.Environments)
        {
            _selected[env] = false;
        }

        RefreshRuns();
    }

    private void Subscribe(JobRun run)
    {
        if (_subscribed.Add(run.Id))
            run.OnUpdated += () => InvokeAsync(RefreshAndRender);
    }

    private void StartJobs()
    {
        var selectedEnvs = _selected.Where(kv => kv.Value).Select(kv => kv.Key).ToList();
        var selectedTables = _selectedTables.Where(kv => kv.Value).Select(kv => kv.Key).ToList();

        foreach (var env in selectedEnvs)
        {
            foreach (var tableKey in selectedTables)
            {
                var opts = new HistoryCleanupOptions(Table: tableKey, Execute: _executeImmediately);
                var run = JobRunner.StartHistoryCleanup(env, opts);
                Subscribe(run);
                _runs.Insert(0, run);
            }
        }

        StateHasChanged();
    }

    private async Task ConfirmAndExecute(JobRun previewRun)
    {
        var count = previewRun.SqlOutput.Count;
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Dette vil kjøre {count} SQL-statements (DELETE/UPDATE) mot {previewRun.Environment}. Kan ikke angres." },
            { x => x.ButtonText, $"Kjør {count} statements" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Bekreft kjøring", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var run = JobRunner.StartHistoryExecute(previewRun.Id, previewRun.Environment);
            Subscribe(run);
            _runs.Insert(0, run);
            StateHasChanged();
        }
    }

    private void RefreshRuns()
    {
        var preview = RunStore.GetForJob(HistoryCleanupJob.JobName).ToList();
        var execute = RunStore.GetForJob($"{HistoryCleanupJob.JobName}:Execute").ToList();
        _runs = preview.Concat(execute)
            .OrderByDescending(r => r.StartedAt)
            .ToList();

        foreach (var run in _runs)
            Subscribe(run);
    }

    private void RefreshAndRender()
    {
        RefreshRuns();
        StateHasChanged();
    }

    private bool AnySelected => _selected.Values.Any(v => v) && _selectedTables.Values.Any(v => v);

    private async Task OpenScheduleDialog()
    {
        var selectedEnvs = _selected.Where(kv => kv.Value).Select(kv => kv.Key).ToList();
        var selectedTables = _selectedTables.Where(kv => kv.Value).Select(kv => kv.Key).ToList();

        var entries = (
            from env in selectedEnvs
            from tableKey in selectedTables
            select new JobScheduleEntry
            {
                Id = $"history-{env.ToLowerInvariant()}-{tableKey.ToLowerInvariant()}",
                JobType = "HistoryCleanup",
                Environment = env,
                Cron = "0 3 * * *",
                Enabled = true,
                HistoryOptions = new ScheduledHistoryOptions
                {
                    Table = tableKey,
                    Execute = _executeImmediately,
                },
            }
        ).ToList();

        var parameters = new DialogParameters<ScheduleConfigDialog>
        {
            { x => x.Entries, entries },
        };

        await DialogService.ShowAsync<ScheduleConfigDialog>("Generer plan-konfig", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    public void Dispose() { /* subscriptions are managed by JobRunCard.Dispose() */ }
}
